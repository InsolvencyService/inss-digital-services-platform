@*
    This component relates to the GDS Design System 'Address' pattern. 
    https://design-system.service.gov.uk/patterns/addresses/
*@

@inherits ControlsBase

<fieldset class="govuk-fieldset" id="@GenerateElementId()">
@*     <FieldSetHeadingText Name="fieldset-address-heading">
        @Text
    </FieldSetHeadingText> *@

    @* <InputHeadingText Name="address-heading">@Text</InputHeadingText> *@

    @* <Input Name="aboutYou.FirstName" Text="First name" Placeholder="Enter your first name" Value="@aboutYou.FirstName" /> *@

    <Input Id="idAddress1" text="Address line 1" Name="@AddressLines.Address1" SmallText="true" Value="@AddressLines.Address1" />
    <Input Id="idAddress2" text="Address line 2" Name="@AddressLines.Address2" SmallText="true" Value="@AddressLines.Address2" />
    <Input Id="idTown" text="Town" Name="@AddressLines.Town" SmallText="true" Value="@AddressLines.Town" />
    <Input Id="idPostcode" text="Postcode" Name="@AddressLines.Postcode" SmallText="true" Value="@AddressLines.Postcode" />

</fieldset>


@code {
    [CascadingParameter]
    private EditContext? EditContext { get; set; }

    [Parameter]
    public string Text { get; set; } = string.Empty;

    [CascadingParameter]
    public Address AddressLines { get; set; } = new Address();



}
