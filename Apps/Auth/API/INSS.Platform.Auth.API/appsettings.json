{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "KeyVault": {
    "Uri": "<Key Vault URI>"
  },
  "OneLogin": {
    "ClientId": "<OneLogin ClientID>",
    "SignInUri": "<OneLogin ClientID>",
    "TokenUri": "<OneLogin ClientID>",
    "RedirectUri": "<OneLogin ClientID>",
    "Scopes": "<OneLogin ClientID>",
    "ClientAssertionKeyFile": "<Only supply if the environment has no access to the key vault e.g. dev environment>"
  },
  "StateCache": {
    // This in-memory cache is used to store state e.g. UserId, ClientUrl between requests to OneLogin.
    // This should be swapped out for a distributed cache in a production environment.
    "AutoCleanupInMinutes": 15,
    "ItemExpiryInMinutes": 10
  },
  "ApplicationInsights": {
    "InstrumentationKey": "YOUR_INSTRUMENTATION_KEY",
    "EnableAdaptiveSampling": "true",
    "EnablePerformanceCounterCollectionModule": "true",
    "EnableAppServicesHeartbeat": "true"
  }
}