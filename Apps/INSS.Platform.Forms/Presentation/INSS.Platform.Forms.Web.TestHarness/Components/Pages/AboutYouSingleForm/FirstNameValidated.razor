@page "/about-you/first-name-validated"

@using INSS.Platform.Common.Libs.Components.Models
@using INSS.Platform.Forms.Web.TestHarness.Common.Services

@inject IPropertyValidator PropertyValidator;

<EditForm Enhance EditContext="CurrentEditContext" FormName="about-you" OnValidSubmit="SubmitForm">
    <InputValidated Name="aboutYou.FirstName" Type="InputFieldType.Text" Text="Email" Placeholder="Enter your first name" Value="@aboutYou.FirstName" ValidateFor="() => aboutYou.FirstName" HideErrorSummary="true" />
    <SubmitButton Name="about-you-submit" Text="Submit" />
</EditForm>

@code {
    [SupplyParameterFromForm]
    private AboutYou aboutYou { get; set; } = new AboutYou();

    protected EditContext CurrentEditContext { get; set; } = null!;

    protected override void OnInitialized()
    {
        CurrentEditContext = new EditContext(aboutYou);

        base.OnInitialized();
    }

    private void SubmitForm()
    {
        Console.WriteLine($"First name: {aboutYou.FirstName}");

        var modifiedForm = CurrentEditContext.Model as AboutYou ?? new();
        var cachedForm = new AboutYou(); // This would be written to a database or session in a real app

        ValidateAndAssignFormProperty(modifiedForm, cachedForm, nameof(aboutYou.FirstName));
    }

    protected bool ValidateAndAssignFormProperty(AboutYou formToValidate, AboutYou formToPersist, string property)
    {
        var value = formToValidate.GetType().GetProperty(property)?.GetValue(formToValidate);

        var errors = PropertyValidator.ValidateProperties(formToValidate, new[] { property });
        if (errors.Any())
        {
            var validationMessageStore = new ValidationMessageStore(CurrentEditContext);
            foreach (var error in errors)
            {
                var fieldIdentifier = new FieldIdentifier(aboutYou, error.MemberNames.First());
                validationMessageStore.Add(fieldIdentifier, error.ErrorMessage!);
            }

            // Show the validation message.
            CurrentEditContext.NotifyValidationStateChanged();

            // Ensure the invalid value remains in the form for user correction.
            SetPropertyValueByName(aboutYou, property, value);

            return false;
        }

        // Set the valid value to the item to persist
        SetPropertyValueByName(formToPersist, property, value);

        return true;
    }

    protected void SetPropertyValueByName(object target, string propertyName, object? value)
    {
        var property = target.GetType().GetProperty(propertyName);
        if (property != null && property.CanWrite)
        {
            property.SetValue(target, value);
        }
    }
}
