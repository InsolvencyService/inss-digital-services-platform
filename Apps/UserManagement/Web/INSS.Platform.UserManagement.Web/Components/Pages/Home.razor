@page "/"
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation

<PageTitle>Insolvency Service</PageTitle>

<div class="govuk-width-container">
    <main class="govuk-main-wrapper" id="main-content">
        <h1 class="govuk-heading-xl">One Login Demo</h1>

        <p class="govuk-body">Welcome to the Insolvency Service One Login demo application.</p>
        <p class="govuk-body">This application is built using Blazor and demonstrates the ability to login to the application using One Login.</p>

        @if (IsSignedIn)
        {
            <h3 class="govuk-heading-m"><b>You are logged in!</b></h3>
            <p class="govuk-body">To sign out, please <b>click the 'sign out' button</b> in the top right corner.</p>
        }
        else
        {
            <p class="govuk-body">To get started, <b>please click the login button</b> in the top right corner.</p>
        }

    </main>
</div>

@code {
    private bool IsSignedIn { get; set; } = false;

    protected override void OnInitialized()
    {
        var uri = new Uri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        var AccessToken = query.TryGetValue("access_token", out var token) ? token.ToString() : null;
        IsSignedIn = !string.IsNullOrEmpty(AccessToken);
    }
}
