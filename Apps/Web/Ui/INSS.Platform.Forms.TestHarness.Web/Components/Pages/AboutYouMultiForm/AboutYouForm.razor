@using INSS.Platform.Components.Web.Common.Enums
@using INSS.Platform.Components.Web.Helpers
@using INSS.Platform.Components.Web.Models
@using INSS.Platform.Forms.TestHarness.Web.Models
omponents.Shared.Enums
@page "/about-you"

<EditForm FormName="about-you" Model="aboutYou" OnSubmit="SubmitForm">
    <Input Name="aboutYou.FirstName" Text="First name" Placeholder="Enter your first name" Value="@aboutYou.FirstName" />
    <Input Name="aboutYou.LastName" Text="Last name" Placeholder="Enter your last name" Value="@aboutYou.LastName" />
    <Input Name="aboutYou.Email" Type="InputFieldType.Email" Text="Email" Placeholder="Enter your email" Value="@aboutYou.Email" />
    <Input Name="aboutYou.Telephone" Type="InputFieldType.Telephone" Text="Telephone" Placeholder="Enter your telephone number" Value="@aboutYou.Telephone" />
    <Input Name="aboutYou.Salary" Type="InputFieldType.Currency" Text="Salary" Placeholder="Enter your salary" Value="@aboutYou.Salary.ToString()" />

    <RadioButtons Name="aboutYou.Employed" Text="Are you employed" Inline="false" Value="@aboutYou.Employed.ToString()" Items="@employedStatus" />

    <SubmitButton Name="about-you-submit" Text="Submit" />
</EditForm>

@code {
    [SupplyParameterFromForm]
    private AboutYou aboutYou { get; set; } = new AboutYou();

    public List<RadioOption<string>> employedStatus { get; set; } = EnumHelper.ToRadioOptions<YesNoType>();
 
    private void SubmitForm()
    {
        Console.WriteLine($"First name: {aboutYou.FirstName}");
    }
}
