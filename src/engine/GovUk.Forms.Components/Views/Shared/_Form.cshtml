@model FormModel

<govuk-task-list>
    @foreach(SectionModel section in Model.Sections)
    {
        <govuk-task-list-item 
            name="@(section.Title)" 
            is-complete="@(section.IsComplete)" 
            state="@(section.GetState())" 
            url="@(section.FirstPage.Path)" />
    }
</govuk-task-list>