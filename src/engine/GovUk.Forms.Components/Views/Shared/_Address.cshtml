@model AddressModel

<govuk-fieldset>
    <govuk-fieldset-legend class="govuk-fieldset__legend govuk-fieldset__legend--l">@(Model.MetaData.Question ?? "What is your address?")</govuk-fieldset-legend>

    <govuk-input for="@Model.AddressLine1" input-attributes="@InputAttributes.AutoFocus" input-class="govuk-input--width-30" inputmode="text" spellcheck="false">
        <govuk-input-label is-page-heading="false" class="govuk-label">Address Line 1</govuk-input-label>
    </govuk-input>

    <govuk-input for="@Model.AddressLine2" input-class="govuk-input--width-30" inputmode="text" spellcheck="false">
        <govuk-input-label is-page-heading="false" class="govuk-label">Address line 2 (optional)</govuk-input-label>
    </govuk-input>

    <govuk-input for="@Model.TownCity" input-class="govuk-input--width-20" inputmode="text" spellcheck="false">
        <govuk-input-label is-page-heading="false" class="govuk-label">Town or city</govuk-input-label>
    </govuk-input>

    <govuk-input for="@Model.County" input-class="govuk-input--width-20" inputmode="text" spellcheck="false">
        <govuk-input-label is-page-heading="false" class="govuk-label">County (optional)</govuk-input-label>
    </govuk-input>

    <govuk-input for="@Model.Postcode" input-class="govuk-input--width-10" inputmode="text" spellcheck="false">
        <govuk-input-label is-page-heading="false" class="govuk-label">Postcode</govuk-input-label>
    </govuk-input>

</govuk-fieldset>