@model DateModel

<govuk-date-input id="Date" for="@Model.Value">
    <govuk-date-input-fieldset>
        <govuk-date-input-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
            @(Model.MetaData.Question.Or("What is the date?"))
        </govuk-date-input-fieldset-legend>
        <govuk-date-input-hint>
            @(Model.MetaData.Hint.Or("For example, 27 03 2025"))
        </govuk-date-input-hint>
        <govuk-date-input-day value="@Model.Day" />
        <govuk-date-input-month value="@Model.Month" />
        <govuk-date-input-year value="@Model.Year" />
    </govuk-date-input-fieldset>
</govuk-date-input>

