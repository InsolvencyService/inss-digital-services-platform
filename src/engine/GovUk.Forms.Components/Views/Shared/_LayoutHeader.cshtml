@inject IOptions<HeaderOptions> Header

<govuk-header home-page-url="@(Header.Value.HomeLink)" />
<govuk-service-navigation service-name="@(Header.Value.Service.Label)" service-url="@(Header.Value.Service.Link)" />
<div class="govuk-width-container">
    <div class="govuk-phase-banner">
        <p class="govuk-phase-banner__content">
            <strong class="govuk-tag govuk-phase-banner__content__tag">
                Beta
            </strong>
            <span class="govuk-phase-banner__text">
                This is a new service. Help us improve it and <a class="govuk-link" href="https://www.smartsurvey.co.uk/s/DirectorConductReportingService/" rel="noreferrer noopener" target="_blank">give your feedback (opens in new tab)</a>.
            </span>
        </p>
    </div>
</div>