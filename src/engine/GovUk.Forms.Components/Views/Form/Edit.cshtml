@model ContentModel

@{
    string? submitButtonText = Model.GetSubmitButtonText();
}

@using (Html.BeginForm(Model))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.Id.Value)
    @Html.HiddenFor(m => m.Path.Value)
    @Html.HiddenFor(m => m.TypeName)
    @Html.HiddenFor(m => m.ViewName)

    if (Model.IsPageModel())
    {
        @Html.HiddenFor(m => ((PageModel)m).LinkedToNode.Value)
    }
    
    @await Html.PartialAsync(Model.ViewName, Model)
    
    @if (Model is FormModel form)
    {
        if (form.SubmitType == SubmitTypes.Form && submitButtonText is not null)
        {
            <govuk-button type="submit" disabled="!@form.CanSubmit">@submitButtonText</govuk-button>
        }
    }
    else 
    {
        @if (submitButtonText is not null)
        {
            <govuk-button type="submit">@submitButtonText</govuk-button>
        }
    }
}