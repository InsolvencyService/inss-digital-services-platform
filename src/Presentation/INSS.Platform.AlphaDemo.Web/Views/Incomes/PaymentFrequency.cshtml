@model IncomeModel

@{
    ViewData["Title"] = "Alpha Demo - Income";
    string action = nameof(IncomesController.PaymentFrequency);
}

<inss-previous-button previous-url="@Url.Action(nameof(IncomesController.GrossIncome))" />

<form asp-action="@action" method="post">

    @await Html.PartialAsync($"_{action}", Model.PaymentFrequency)

    <govuk-button type="submit">Next</govuk-button>

</form>


