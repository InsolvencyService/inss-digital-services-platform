@model AboutYouModel

@{
    string action = nameof(AboutYouController.EmailAddress);
}

<inss-previous-button previous-url="@Url.Action(nameof(AboutYouController.TelephoneNumber))" />

<form asp-action="@action" method="post">

    @await Html.PartialAsync($"_{action}", Model.EmailAddress)

    <govuk-button type="submit">Next</govuk-button>

</form>


