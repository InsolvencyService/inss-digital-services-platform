@model AboutYouModel

@{
    ViewData["Title"] = "Alpha Demo - About you";
    string action = nameof(AboutYouController.TelephoneNumber);
}

<inss-previous-button previous-url="@Url.Action(nameof(AboutYouController.UserAddress))" />

<form asp-action="@action" method="post">

    @await Html.PartialAsync($"_{action}", Model.TelephoneNumber)

    <govuk-button type="submit">Next</govuk-button>
</form>


