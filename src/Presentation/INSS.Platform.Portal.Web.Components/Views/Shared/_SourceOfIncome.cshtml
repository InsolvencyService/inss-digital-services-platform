@using INSS.Platform.Shared.Web.Utilities
@model SourceOfIncomeModel

<govuk-radios for="@Model.SourceOfIncome" orientation="Vertical">
    <govuk-radios-fieldset>
        <govuk-radios-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
            What is the source of income?
        </govuk-radios-fieldset-legend>
        <govuk-radios-hint>
            Select one option
        </govuk-radios-hint>

        @foreach (var option in EnumExtensions.GetValuesAndDescriptions<IncomeSource>())
        {
            <govuk-radios-item value="@option.Key">@option.Value</govuk-radios-item>
        }

    </govuk-radios-fieldset>
</govuk-radios>
<inss-error-message asp-for="@Model.SourceOfIncome" />