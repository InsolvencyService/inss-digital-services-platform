@model INSS.Platform.Portal.Domain.ConfirmModel

<govuk-radios for="@Model.Confirmed" orientation="Vertical">
    <govuk-radios-fieldset>
        <govuk-radios-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
            @(Model.Question ?? "Confirm Remove?")
        </govuk-radios-fieldset-legend>
        <govuk-radios-hint>
            Select one option
        </govuk-radios-hint>
        <govuk-radios-item value="true">Yes</govuk-radios-item>
        <govuk-radios-item value="false">No</govuk-radios-item>
    </govuk-radios-fieldset>
</govuk-radios>
<inss-error-message asp-for="@Model.Confirmed" />