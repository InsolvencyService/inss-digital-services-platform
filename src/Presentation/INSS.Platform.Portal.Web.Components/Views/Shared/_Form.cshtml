@using INSS.Platform.Portal.Domain
@model INSS.Platform.Portal.Domain.FormModel

<inss-task-list>
    @foreach(var section in Model.Sections)
    {
        <inss-task-list-item name="@(section.Name)" is-complete="@(section.Progress == SectionProgressType.Completed)" url="@(section.Context.FirstPageUrl)" />
    }
</inss-task-list>
