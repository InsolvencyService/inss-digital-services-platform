@using INSS.Platform.Portal.Domain
@model INSS.Platform.Portal.Domain.AddAnotherModel

@foreach (BaseModel[] items in Model.Items)
{
    <govuk-summary-card>
        <govuk-summary-card-title>@Model.Name</govuk-summary-card-title>
        <govuk-summary-card-actions>
            <govuk-summary-card-action href="@(Model.GetChangeUrl(items.First()))" visually-hidden-text="@items.First().Name">Change</govuk-summary-card-action>
            <govuk-summary-card-action href="@(Model.GetRemoveUrl(items.First()))" visually-hidden-text="@items.First().Name">Remove</govuk-summary-card-action>
        </govuk-summary-card-actions>
        <govuk-summary-list>
            @foreach (BaseModel item in items)
            {
                <govuk-summary-list-row>
                    <govuk-summary-list-row-key>@item.Name</govuk-summary-list-row-key>
                    <govuk-summary-list-row-value>
                    @foreach (var propValue in item.GetValues())
                    {
                        <p class="govuk-body">@(propValue)</p>
                    }
                    </govuk-summary-list-row-value>
                </govuk-summary-list-row>
            }
        </govuk-summary-list>
    </govuk-summary-card>
}
<govuk-button-link href="@(Model.GetFirstPage().PageUrl)">Add Another</govuk-button-link>