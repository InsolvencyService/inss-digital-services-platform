@model AboutYouModel

<govuk-fieldset>
    <govuk-fieldset-legend class="govuk-fieldset__legend govuk-fieldset__legend--l">What is your address?</govuk-fieldset-legend>

    <govuk-input for="@Model.Address.AddressLine1" input-class="govuk-input--width-30" inputmode="text" spellcheck="false">
        <govuk-input-label is-page-heading="false" class="govuk-label">Address Line 1</govuk-input-label>
    </govuk-input>
    <inss-error-message asp-for="@Model.Address.AddressLine1"/>

    <govuk-input for="@Model.Address.AddressLine2" input-class="govuk-input--width-30" inputmode="text" spellcheck="false">
        <govuk-input-label is-page-heading="false" class="govuk-label">Address line 2 (optional)</govuk-input-label>
    </govuk-input>
    <inss-error-message asp-for="@Model.Address.AddressLine2" />

    <govuk-input for="@Model.Address.TownCity" input-class="govuk-input--width-20" inputmode="text" spellcheck="false">
        <govuk-input-label is-page-heading="false" class="govuk-label">Town or city</govuk-input-label>
    </govuk-input>
    <inss-error-message asp-for="@Model.Address.TownCity" />

    <govuk-input for="@Model.Address.County" input-class="govuk-input--width-20" inputmode="text" spellcheck="false">
        <govuk-input-label is-page-heading="false" class="govuk-label">County (optional)</govuk-input-label>
    </govuk-input>
    <inss-error-message asp-for="@Model.Address.County" />

    <govuk-input for="@Model.Address.Postcode" input-class="govuk-input--width-10" inputmode="text" spellcheck="false">
        <govuk-input-label is-page-heading="false" class="govuk-label">Postcode</govuk-input-label>
    </govuk-input>
    <inss-error-message asp-for="@Model.Address.Postcode"/>

</govuk-fieldset>
