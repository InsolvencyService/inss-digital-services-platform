<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="Code Coverage" uri="datacollector://Microsoft/CodeCoverage/2.0" assemblyQualifiedName="Microsoft.VisualStudio.Coverage.DynamicCoverageDataCollector, Microsoft.VisualStudio.TraceCollector, Version=11.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a">
        <Configuration>
          <CodeCoverage>
            <ModulePaths>
              <Exclude>
                <!-- Exclude test projects -->
                <ModulePath>.*\.Tests\.dll$</ModulePath>
                <ModulePath>.*\.Test\.dll$</ModulePath>
                <ModulePath>.*tests\.dll$</ModulePath>
                
                <!-- Exclude system assemblies -->
                <ModulePath>.*System\..*\.dll$</ModulePath>
                <ModulePath>.*Microsoft\..*\.dll$</ModulePath>
                <ModulePath>.*mscorlib\.dll$</ModulePath>
                <ModulePath>.*netstandard\.dll$</ModulePath>
              </Exclude>
            </ModulePaths>
            
            <!-- Optionally exclude by namespace -->
            <Functions>
              <Exclude>
                <Function>^System\..*</Function>
                <Function>^Microsoft\..*</Function>
              </Exclude>
            </Functions>
          </CodeCoverage>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
